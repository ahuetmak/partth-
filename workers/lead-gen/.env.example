# B2B Lead Gen Worker — Configura estas variables en Cloudflare (wrangler secret put)
# Nunca commits .env con valores reales

# Apify webhook (opcional, para verificar firma)
# APIFY_WEBHOOK_SECRET=

# SerpApi
# SERPAPI_KEY=

# MillionVerifier
# MILLION_VERIFIER_KEY=
# MILLIONVERIFY_API_KEY=

# Resend
# RESEND_API_KEY=
# FROM_EMAIL=PARTTH <leads@partth.com>

# PayPal
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_WEBHOOK_SECRET=

# Supabase
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Opcionales
# RETURN_URL=https://partth.com/gracias
# CANCEL_URL=https://partth.com

# Control de concurrencia (escala estatal)
# USE_QUEUE=true          # Cola de leads; webhook devuelve 202, cron procesa
# QUEUE_BATCH_SIZE=5      # Leads por ejecución del cron
# DELAY_BETWEEN_CONTRACTORS=500  # ms entre cada email/API externa

# Growth Agent (6 AM San Antonio)
# GEMINI_API_KEY=         # Gemini SDK para análisis/segmentación/redacción
# GROWTH_MAX_PROSPECTS=100
# GROWTH_JOIN_BASE=       # URL base para registro (ej. https://lead-gen.xxx.workers.dev)
